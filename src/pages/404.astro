---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page Not Found - SkillStart Jobs" description="The requested page could not be found.">
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumbs"><a href="/">Home</a> / 404</div>
      <h1>Page Not Found</h1>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <article class="content-card">
        <p>The page you requested does not exist or may have moved.</p>
        <p><a class="btn-primary" href="/">Go back to homepage</a></p>
      </article>
    </div>
  </section>
</BaseLayout>
