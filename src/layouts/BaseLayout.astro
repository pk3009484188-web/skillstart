---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = "SkillStart Jobs helps beginner candidates find trusted jobs in Pakistan.", canonical } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return path === "/";
  return path.startsWith(href);
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,300&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="header">
    <div class="container nav-inner">
      <a class="logo" href="/">Skill<span>Start</span> Jobs</a>
      <nav class="nav-links" aria-label="Main navigation">
        <a href="/" class={isActive("/") ? "active" : undefined}>Home</a>
        <a href="/latest-jobs/" class={isActive("/latest-jobs") || isActive("/jobs") ? "active" : undefined}>Latest Jobs</a>
        <a href="/category/matric-jobs/" class={isActive("/category") ? "active" : undefined}>Categories</a>
        <a href="/blog/" class={isActive("/blog") ? "active" : undefined}>Blog</a>
        <a href="/about/" class={isActive("/about") ? "active" : undefined}>About</a>
        <a href="/contact/" class={isActive("/contact") ? "active" : undefined}>Contact</a>
      </nav>
      <div class="nav-actions">
        <input class="search-input" type="search" placeholder="Search jobs" aria-label="Search jobs" />
        <a class="btn-small" href="/latest-jobs/">View Latest Jobs</a>
      </div>
      <button class="menu-btn" aria-label="Open menu">Menu</button>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer>
    <div class="container footer-inner">
      <div class="footer-grid">
        <div>
          <a class="logo" href="/">Skill<span>Start</span> Jobs</a>
          <p>Helpful job discovery platform for fresh and low-experience candidates in Pakistan.</p>
        </div>
        <div>
          <h4>Explore</h4>
          <a href="/latest-jobs/">Latest Jobs</a>
          <a href="/blog/">Blog</a>
          <a href="/category/matric-jobs/">Categories</a>
        </div>
        <div>
          <h4>Company</h4>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="#">Advertise</a>
        </div>
        <div>
          <h4>Legal</h4>
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms/">Terms</a>
          <a href="/disclaimer/">Disclaimer</a>
          <a href="/cookie-policy/">Cookie Policy</a>
          <a href="/dmca/">DMCA</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div>Copyright 2026 SkillStart Jobs</div>
        <div>Powered by SkillStart Jobs</div>
      </div>
    </div>
  </footer>

  <script is:inline src="/scripts/main.js"></script>
</body>
</html>
